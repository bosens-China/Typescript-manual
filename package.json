{
  "name": "typescript-manual",
  "version": "1.0.0",
  "description": "TypeScript 中文手册，使用vuepress构建。",
  "license": "MIT",
  "keywords": [
    "typescript",
    "docs"
  ],
  "author": "boses",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "build": "tsx src/main.ts && pnpm run docs:build",
    "lint": "eslint src/ docs/ --ignore-pattern docs/download",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md,vue,css,scss,html,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@vuepress/plugin-active-header-links": "^1.4.1",
    "@vuepress/plugin-back-to-top": "^1.4.1",
    "@vuepress/plugin-nprogress": "^1.4.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "md-imgage-error-loader": "^1.0.4",
    "prettier": "^3.8.4",
    "tinyglobby": "^0.2.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vuepress": "^1.8.0",
    "vuepress-plugin-baidu-autopush": "^1.0.1",
    "vuepress-plugin-pangu": "^1.0.1",
    "vuepress-plugin-reading-progress": "^1.0.9"
  },
  "dependencies": {
    "@vuepress/shared-utils": "^1.8.0",
    "babel-polyfill": "^6.26.0",
    "dayjs": "^1.8.26",
    "loader-utils": "^2.0.0",
    "markdown-it": "^10.0.0",
    "vue": "^2.6.12",
    "vue-clipboard2": "^0.3.1",
    "vue-m-message": "^3.1.0",
    "vuepress-theme-default-prefers-color-scheme": "^2.0.0"
  }
}
